[submodule "atf"]
	path = atf
	url = https://github.com/ARM-software/arm-trusted-firmware.git
[submodule "u-boot"]
	path = u-boot
	url = https://github.com/u-boot/u-boot.git
[submodule "buildroot"]
	path = buildroot
	url = https://github.com/buildroot/buildroot.git
[submodule "linux"]
	path = linux
	url = https://github.com/torvalds/linux.git
